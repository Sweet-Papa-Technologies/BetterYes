# FOREMAN secrets — copy to .env and fill in, OR (on macOS) store these in the Keychain via
#   pnpm foreman secret set <NAME>
# Resolution precedence: process env  >  .env  >  macOS Keychain.
# `foreman init` provisions and stores most of these for you.

# Bearer token the dashboard/API requires (generated by `foreman init`).
FOREMAN_TOKEN=

# Key FOREMAN sends to your LiteLLM proxy (generated by `foreman init`).
LITELLM_KEY=

# Gemini API key the LiteLLM proxy uses upstream (provisioned by `foreman init` via gcloud).
GEMINI_API_KEY=

# ── Reserved for later milestones ────────────────────────────────────────────
# Hermes HTTP API key — required even on loopback (M4).
# HERMES_API_KEY=
# Web Push VAPID keys (M4).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Optional ntfy topic (M4).
# FOREMAN_NTFY_TOPIC=
